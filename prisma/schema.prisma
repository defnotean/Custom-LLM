// Prisma schema — relational spine for the Discord AI platform.
// Vector data lives alongside (pgvector table managed by PgVectorMemoryStore,
// or Qdrant via vectorId references). See docs/ARCHITECTURE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id            String   @id @default(cuid())
  discordUserId String   @unique
  username      String
  displayName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GuildProfile {
  id             String   @id @default(cuid())
  discordGuildId String   @unique
  name           String
  settingsJson   Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ChannelProfile {
  id               String   @id @default(cuid())
  discordChannelId String   @unique
  guildId          String?
  name             String
  settingsJson     Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Conversation {
  id                String   @id @default(cuid())
  guildId           String?
  channelId         String
  userId            String
  discordMessageId  String
  userMessage       String
  assistantResponse String?
  metadataJson      Json     @default("{}")
  createdAt         DateTime @default(now())

  @@index([channelId, createdAt])
  @@index([userId, createdAt])
}

enum MemoryScope {
  USER
  GUILD
  CHANNEL
  GLOBAL
}

model Memory {
  id           String      @id @default(cuid())
  userId       String?
  guildId      String?
  channelId    String?
  scope        MemoryScope
  content      String
  summary      String?
  importance   Int         @default(1)
  metadataJson Json        @default("{}")
  vectorId     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([scope, userId])
  @@index([scope, guildId])
  @@index([scope, channelId])
}

model ToolLog {
  id           String   @id @default(cuid())
  toolName     String
  toolCategory String
  guildId      String?
  channelId    String?
  userId       String?
  inputJson    Json
  outputJson   Json?
  error        String?
  latencyMs    Int?
  success      Boolean
  createdAt    DateTime @default(now())

  @@index([toolName, createdAt])
  @@index([success])
}

enum TrainingSource {
  CONVERSATION
  TOOL_CALL
  SYNTHETIC
  FEEDBACK
}

enum TrainingFormat {
  CHATML
  ALPACA
  TOOL_CALLING_JSONL
}

model TrainingExample {
  id           String         @id @default(cuid())
  source       TrainingSource
  format       TrainingFormat
  inputJson    Json
  outputJson   Json
  qualityScore Float?
  reviewed     Boolean        @default(false)
  metadataJson Json           @default("{}")
  createdAt    DateTime       @default(now())

  @@index([format, createdAt])
  @@index([source])
}

enum LearningKind {
  MEMORY
  SKILL
  PREFERENCE
  CORRECTION
  EVAL_FAILURE
  VOICE_SUMMARY
  DOCUMENT
}

enum LearningReviewStatus {
  CANDIDATE
  APPROVED
  REJECTED
}

enum TrainingPromotionStatus {
  NOT_QUEUED
  QUEUED
  TRAINED
  BLOCKED
}

model LearnedItem {
  id               String                  @id @default(cuid())
  kind             LearningKind
  content          String
  source           String
  confidence       Float                   @default(0.5)
  reviewStatus     LearningReviewStatus    @default(CANDIDATE)
  trainingStatus   TrainingPromotionStatus @default(NOT_QUEUED)
  accessPathsJson  Json                    @default("[]")
  provenanceJson   Json                    @default("{}")
  retentionJson    Json                    @default("{}")
  trainingJson     Json                    @default("{}")
  metadataJson     Json                    @default("{}")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  parameterLinks   LearnedParameterModule[]

  @@index([kind, createdAt])
  @@index([reviewStatus])
  @@index([trainingStatus])
}

enum ParameterModuleKind {
  BASE_MODEL
  ADAPTER
  ROUTER
  SPECIALIST
  EXPERT
  MERGED_CHECKPOINT
  ENSEMBLE_MEMBER
}

enum ParameterModuleStatus {
  STAGED
  ACTIVE
  RETIRED
  REJECTED
}

model ParameterModuleRecord {
  id                        String                   @id @default(cuid())
  name                      String                   @unique
  kind                      ParameterModuleKind
  parameters                BigInt
  activeParameters          BigInt
  trainableParameters       BigInt
  status                    ParameterModuleStatus    @default(STAGED)
  baseModuleId              String?
  route                     String?
  datasetHashesJson         Json                     @default("[]")
  evalReportsJson           Json                     @default("[]")
  sourceLearningItemIdsJson Json                     @default("[]")
  rollbackTargetId          String?
  metadataJson              Json                     @default("{}")
  createdAt                 DateTime                 @default(now())
  promotedAt                DateTime?
  retiredAt                 DateTime?
  learningLinks             LearnedParameterModule[]

  @@index([kind, status])
  @@index([status])
}

model LearnedParameterModule {
  learnedItemId      String
  parameterModuleId  String
  linkedAt           DateTime              @default(now())
  learnedItem        LearnedItem           @relation(fields: [learnedItemId], references: [id], onDelete: Cascade)
  parameterModule    ParameterModuleRecord @relation(fields: [parameterModuleId], references: [id], onDelete: Cascade)

  @@id([learnedItemId, parameterModuleId])
}

model UserFeedback {
  id                String   @id @default(cuid())
  conversationId    String
  userId            String?
  rating            Int?
  feedbackText      String?
  preferredResponse String?
  rejectedResponse  String?
  reviewed          Boolean  @default(false)
  metadataJson      Json     @default("{}")
  createdAt         DateTime @default(now())

  @@index([conversationId])
  @@index([reviewed])
}

enum ToolRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ToolDefinitionRecord {
  id                      String   @id @default(cuid())
  name                    String   @unique
  category                String
  description             String
  schemaJson              Json
  riskLevel               ToolRisk
  enabled                 Boolean  @default(true)
  requiresConfirmation    Boolean  @default(false)
  requiredPermissionsJson Json     @default("[]")
  cooldownSeconds         Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
