# ── Discord ──────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications (see docs/DISCORD_SETUP.md)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: a single guild id for development (faster slash-command registration later)
DISCORD_GUILD_ID=

# ── Data spine ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/custom_discord_ai
REDIS_URL=redis://localhost:6379

# ── LLM provider ─────────────────────────────────────────────────────────────
# LLM_PROVIDER: "openai-compatible" (vLLM / LM Studio / Ollama's /v1) or "ollama" (native /api/chat)
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=local
LLM_MODEL=qwen2.5:7b-instruct

# Native Ollama endpoint (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Optional model-server control endpoint for checked parameter-module hotloading.
# Leave empty unless your serving stack exposes a private POST endpoint that accepts
# the parameter-module-hotload-apply-v1 payload from npm run apply:parameter-hotload.
PARAMETER_HOTLOAD_ENDPOINT=
PARAMETER_HOTLOAD_API_KEY=
PARAMETER_HOTLOAD_TIMEOUT_MS=30000

# ── Embeddings (memory / future tool routing) ────────────────────────────────
# EMBEDDING_PROVIDER: "local" (OpenAI-compatible /v1/embeddings at EMBEDDING_BASE_URL)
# or "hashing" (deterministic offline fallback — NOT semantic, dev/tests only)
EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text

# ── Vector store ─────────────────────────────────────────────────────────────
# VECTOR_STORE: "qdrant" | "pgvector" | "memory" (in-process, non-persistent fallback)
VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=discord_ai_memory

# ── Bot behavior ─────────────────────────────────────────────────────────────
BOT_PREFIX=!
LOG_LEVEL=info
MEMORY_ENABLED=true
TOOL_CALLING_ENABLED=true
# TOOL_ROUTER_STRATEGY: "keyword" (deterministic default) or "embedding" (semantic tool retrieval with keyword fallback)
TOOL_ROUTER_STRATEGY=keyword
TRAINING_LOGGING_ENABLED=true
SAFETY_ENABLED=true

# ── API server (health/tools/memory/training routes) ─────────────────────────
API_PORT=3000
API_HOST=0.0.0.0
