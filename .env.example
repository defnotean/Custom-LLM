# ── Discord ──────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications (see docs/DISCORD_SETUP.md)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: a single guild id for fast `npm run register:discord-commands` development registration.
DISCORD_GUILD_ID=
# Optional Irene presence once Discord login succeeds.
# DISCORD_PRESENCE_STATUS: "online" | "idle" | "dnd" | "invisible"
DISCORD_PRESENCE_STATUS=online
# DISCORD_PRESENCE_ACTIVITY_TYPE: "Playing" | "Listening" | "Watching" | "Competing" | "Custom"
DISCORD_PRESENCE_ACTIVITY_TYPE=Listening
DISCORD_PRESENCE_ACTIVITY_NAME=for tool calls

# Optional private TTS endpoint for !ai voice say.
# Contract: POST JSON {text, voice, format, metadata}; return audio bytes or JSON {audioBase64}.
VOICE_TTS_ENDPOINT=
VOICE_TTS_API_KEY=
VOICE_TTS_VOICE=irene
VOICE_TTS_FORMAT=ogg-opus
# VOICE_TTS_STREAM_TYPE: "arbitrary" | "ogg/opus" | "opus" | "raw"
VOICE_TTS_STREAM_TYPE=arbitrary
VOICE_TTS_TIMEOUT_MS=30000
VOICE_TTS_PLAYBACK_TIMEOUT_MS=120000
VOICE_SPEECH_MAX_CHARS=600
VOICE_SPEECH_MAX_QUEUE_DEPTH=3
VOICE_SPEECH_COOLDOWN_MS=3000

# Optional private STT endpoint for opt-in voice listening/transcription.
# Contract: POST JSON {audioBase64, format, language, metadata}; return JSON {text, confidence?, language?, durationMs?}.
VOICE_STT_ENDPOINT=
VOICE_STT_API_KEY=
VOICE_STT_MODEL=
VOICE_STT_LANGUAGE=auto
VOICE_STT_FORMAT=ogg-opus
VOICE_RECEIVE_FORMAT=discord-opus-packets
VOICE_STT_TIMEOUT_MS=30000

# ── Data spine ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/custom_discord_ai
REDIS_URL=redis://localhost:6379
# RUNTIME_STATE_STORE: "memory" (single-process default) or "redis" (shared cooldown/rate-limit/confirmation/job state)
RUNTIME_STATE_STORE=memory
REDIS_KEY_PREFIX=irene
REDIS_CONNECT_TIMEOUT_MS=2000

# ── LLM provider ─────────────────────────────────────────────────────────────
# LLM_PROVIDER: "openai-compatible" (vLLM / LM Studio / Ollama's /v1) or "ollama" (native /api/chat)
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=local
LLM_MODEL=qwen2.5:7b-instruct

# Native Ollama endpoint (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Optional SubQ / subquadratic sparse-attention long-context provider.
# SubQ is OpenAI-compatible, but access, base URLs, and model IDs are account/private-preview specific.
SUBQ_ENABLED=false
SUBQ_BASE_URL=
SUBQ_API_KEY=
SUBQ_MODEL=
SUBQ_TIMEOUT_MS=600000
# Default false: long-context/SubQ requests fail instead of silently falling back to dense local context.
SUBQ_ALLOW_DENSE_FALLBACK=false

# Optional model-server control endpoint for checked parameter-module hotloading.
# Leave empty unless your serving stack exposes a private POST endpoint that accepts
# the parameter-module-hotload-apply-v1 payload from npm run apply:parameter-hotload.
PARAMETER_HOTLOAD_ENDPOINT=
PARAMETER_HOTLOAD_API_KEY=
PARAMETER_HOTLOAD_TIMEOUT_MS=30000
PARAMETER_HOTLOAD_CONTROL_HOST=127.0.0.1
PARAMETER_HOTLOAD_CONTROL_PORT=8088
# PARAMETER_HOTLOAD_BACKEND: "state-only" or "http".
# "http" posts parameter-hotload-backend-v1 load/rollback payloads to a private model-server adapter sidecar.
PARAMETER_HOTLOAD_BACKEND=state-only
PARAMETER_HOTLOAD_BACKEND_URL=
PARAMETER_HOTLOAD_BACKEND_API_KEY=
PARAMETER_HOTLOAD_BACKEND_TIMEOUT_MS=30000

# Optional private model-adapter sidecar behind PARAMETER_HOTLOAD_BACKEND=http.
# vLLM provider calls /v1/load_lora_adapter and /v1/unload_lora_adapter.
# Ollama provider creates adapter models from a Modelfile and unloads them from memory on rollback.
MODEL_ADAPTER_SIDECAR_HOST=127.0.0.1
MODEL_ADAPTER_SIDECAR_PORT=9099
MODEL_ADAPTER_SIDECAR_API_KEY=
MODEL_ADAPTER_PROVIDER=vllm
MODEL_ADAPTER_SERVER_BASE_URL=http://127.0.0.1:8000
MODEL_ADAPTER_SERVER_API_KEY=
MODEL_ADAPTER_TIMEOUT_MS=30000
MODEL_ADAPTER_BASE_MODEL=
MODEL_ADAPTER_NAME_PREFIX=
MODEL_ADAPTER_VLLM_LOAD_IN_PLACE=true
MODEL_ADAPTER_OLLAMA_MODEL_PREFIX=irene-
MODEL_ADAPTER_OLLAMA_DELETE_ON_ROLLBACK=false

# Optional external trainer endpoint. Dispatch stays dry-run unless this is set
# or --endpoint-url is passed to npm run dispatch:parameter-training.
PARAMETER_TRAINER_ENDPOINT=
PARAMETER_TRAINER_API_KEY=
PARAMETER_TRAINER_TIMEOUT_MS=30000
PARAMETER_TRAINER_CONTROL_HOST=127.0.0.1
PARAMETER_TRAINER_CONTROL_PORT=8090
# Optional local/private trainer backend for serve:parameter-trainer.
# Keep state-only unless you have a trusted trainer executable that writes the expected staging manifest.
PARAMETER_TRAINER_BACKEND=state-only
PARAMETER_TRAINER_COMMAND=
PARAMETER_TRAINER_COMMAND_ARGS_JSON=[]
PARAMETER_TRAINER_COMMAND_CWD=
PARAMETER_TRAINER_COMMAND_TIMEOUT_MS=3600000
PARAMETER_TRAINER_REQUIRE_STAGING_MANIFEST=true

# ── Embeddings (memory / future tool routing) ────────────────────────────────
# EMBEDDING_PROVIDER: "local" (OpenAI-compatible /v1/embeddings at EMBEDDING_BASE_URL)
# or "hashing" (deterministic offline fallback — NOT semantic, dev/tests only)
EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text

# ── Vector store ─────────────────────────────────────────────────────────────
# VECTOR_STORE: "qdrant" | "pgvector" | "memory" (in-process, non-persistent fallback)
VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=discord_ai_memory

# ── Bot behavior ─────────────────────────────────────────────────────────────
BOT_PREFIX=!
LOG_LEVEL=info
MEMORY_ENABLED=true
TOOL_CALLING_ENABLED=true
# TOOL_ROUTER_STRATEGY: "keyword" (deterministic default) or "embedding" (semantic tool retrieval with keyword fallback)
TOOL_ROUTER_STRATEGY=keyword
TRAINING_LOGGING_ENABLED=true
SAFETY_ENABLED=true

# ── API server (health/tools/memory/training routes) ─────────────────────────
API_PORT=3000
API_HOST=0.0.0.0
